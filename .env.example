# ============================================
# NUS Campus Intelligent Assistant - Config
# Copy this file to backend/.env and fill in your values
# ============================================

# WaveSpeed AI (LLM - Hackathon Sponsor)
WAVESPEED_API_KEY=your_wavespeed_api_key_here
WAVESPEED_BASE_URL=https://api.wavespeed.ai/api/v3
WAVESPEED_LLM_MODEL=google/gemini-2.5-flash

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://localhost:3000
OPENCLAW_API_KEY=your_openclaw_key_here

# Canvas LMS (NUS)
CANVAS_BASE_URL=https://nus.instructure.com
CANVAS_ACCESS_TOKEN=your_canvas_token_here

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/canvas/oauth2callback
GOOGLE_GCAL_REDIRECT_URI=http://localhost:8000/api/schedule/gcal/callback

# App
SECRET_KEY=change_this_to_a_random_secret
DATABASE_URL=sqlite:///./data/app.db

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password
